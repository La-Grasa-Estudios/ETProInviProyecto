@using EtPro.Models
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@model ManagePermissionsViewModel

@{
    ViewData["Title"] = $"Gestión de Permisos: {Model.UserName}";
    Layout = "_AdminLayout";
}

<div class="container mt-4">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div class="d-flex align-items-center">
            <div style="width: 4px; height: 24px; background-color: #e31e24; margin-right: 10px;"></div>
            <h4 class="mb-0 text-dark fw-bold">@ViewData["Title"]</h4>
        </div>
        <a asp-action="Index" class="btn btn-sm btn-outline-secondary px-3">
            <i class="bi bi-arrow-left me-1"></i> Volver al listado
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success border-0 shadow-sm py-2 small mb-4">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
        </div>
    }

    <div class="row g-4">
        <!-- Columna de Permisos Individuales -->
        <div class="col-md-8">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-white py-3 border-bottom-0">
                    <h6 class="mb-0 fw-bold text-secondary text-uppercase small">Asignación Manual de Permisos</h6>
                </div>
                <div class="card-body">
                    <form asp-action="ManagePermissions" method="post" id="permissionsForm">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="userId" value="@Model.UserId" />

                        <div class="row">
                            @foreach (var category in Model.Permissions.GroupBy(p => p.Category))
                            {
                                <div class="col-md-6 mb-4">
                                    <div class="p-2 bg-light rounded mb-2 border-start border-3" style="border-color: #004d26 !important;">
                                        <span class="fw-bold small text-dark">@category.Key</span>
                                    </div>
                                    @foreach (var perm in category)
                                    {
                                        <div class="form-check form-switch mb-2 ms-2">
                                            <input class="form-check-input custom-switch" type="checkbox"
                                                   name="selectedPermissions" value="@perm.PermissionId"
                                                   id="perm_@perm.PermissionId"
                                            @(perm.Assigned ? "checked" : "") />
                                            <label class="form-check-label small" for="perm_@perm.PermissionId">@perm.Name</label>
                                        </div>
                                    }
                                </div>
                            }
                        </div>

                        <div class="mt-3 pt-3 border-top d-grid">
                            <button type="submit" class="btn text-white shadow-sm" style="background-color: #004d26; border: none;">
                                <i class="bi bi-shield-check me-2"></i> Guardar Cambios Individuales
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- Columna de Plantillas -->
        <div class="col-md-4">
            <div class="card shadow-sm border-0 border-top border-4" style="border-top-color: #e31e24 !important;">
                <div class="card-body">
                    <h6 class="fw-bold text-dark mb-3">Aplicar Plantilla de Perfil</h6>
                    <p class="text-muted small">Seleccione un perfil predefinido para configurar los permisos automáticamente.</p>

                    <form asp-action="ApplyTemplate" method="post" id="templateForm">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="userId" value="@Model.UserId" />

                        <div class="mb-3">
                            <select name="templateId" class="form-select form-select-sm" id="templateSelector">
                                <option value="">-- Seleccione Perfil --</option>
                                @foreach (var template in Model.Templates)
                                {
                                    <option value="@template.Id">@template.Name</option>
                                }
                            </select>
                        </div>

                        <div class="alert alert-warning p-2 rounded-3 border-0 mb-0" style="background-color: rgba(227, 30, 36, 0.05);">
                            <div class="d-flex">
                                <i class="bi bi-exclamation-triangle text-danger me-2"></i>
                                <p class="mb-0 small text-dark" style="font-size: 0.75rem;">
                                    <strong>Atención:</strong> Al aplicar una plantilla se <strong>reemplazarán</strong> todos los permisos actuales del usuario.
                                </p>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <script>
        document.addEventListener('DOMContentLoaded', function () {
        const templateSelector = document.getElementById('templateSelector');
        const templateForm = document.getElementById('templateForm');
        const permissionsForm = document.getElementById('permissionsForm');

        // 1. Confirmación para Guardado Manual de Permisos
        permissionsForm.addEventListener('submit', function (e) {
        e.preventDefault();

        Swal.fire({
        title: '¿Guardar cambios?',
        text: "Se actualizarán los permisos individuales para este usuario.",
        icon: 'question',
        showCancelButton: true,
        confirmButtonColor: '#004d26',
        cancelButtonColor: '#6c757d',
        confirmButtonText: 'Sí, guardar',
        cancelButtonText: 'Cancelar',
        reverseButtons: true
        }).then((result) => {
        if (result.isConfirmed) {
        // Mostrar loader mientras procesa
        Swal.fire({
        title: 'Actualizando permisos',
        html: 'Por favor espere...',
        allowOutsideClick: false,
        didOpen: () => {
        Swal.showLoading();
        }
        });
        permissionsForm.submit();
        }
        });
        });

        // 2. Confirmación para Aplicación de Plantillas
        templateSelector.addEventListener('change', function () {
        if (this.value === "") return;

        const templateName = this.options[this.selectedIndex].text;

        Swal.fire({
        title: '¿Aplicar Plantilla?',
        text: `Esta acción reemplazará TODOS los permisos actuales por los del perfil "${templateName}".`,
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#e31e24', // Rojo para advertencia de reemplazo
        cancelButtonColor: '#6c757d',
        confirmButtonText: 'Sí, aplicar perfil',
        cancelButtonText: 'Cancelar',
        reverseButtons: true
        }).then((result) => {
        if (result.isConfirmed) {
        // Mostrar loader
        Swal.fire({
        title: 'Aplicando perfil',
        allowOutsideClick: false,
        didOpen: () => {
        Swal.showLoading();
        }
        });
        templateForm.submit();
        } else {
        templateSelector.value = ""; // Resetear el select si cancela
        }
        });
        });
        });
    </script>
}

<style>
    body {
    background-color: #f4f6f9;
    }

    .card {
    border-radius: 8px;
    }

    .custom-switch:checked {
    background-color: #004d26 !important;
    border-color: #004d26 !important;
    }

    .form-check-label {
    cursor: pointer;
    color: #495057;
    }

    .bg-light.rounded {
    transition: all 0.2s;
    }

    .bg-light.rounded:hover {
    background-color: #f0f2f5 !important;
    }

    .form-select:focus {
    border-color: #004d26;
    box-shadow: 0 0 0 0.2rem rgba(0, 77, 38, 0.15);
    }
</style>