@using EtPro.Models
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@model ManagePermissionsViewModel
@{
    ViewData["Title"] = $"Permisos de {Model.UserName}";
}
<h2>@ViewData["Title"]</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<div class="row">
    <div class="col-md-8">
        <h5>Permisos individuales</h5>
        <form asp-action="ManagePermissions" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="userId" value="@Model.UserId" />

            @foreach (var category in Model.Permissions.GroupBy(p => p.Category))
            {
                <h6>@category.Key</h6>
                foreach (var perm in category)
                {
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox"
                               name="selectedPermissions" value="@perm.PermissionId"
                               @(perm.Assigned ? "checked" : "") />
                        <label class="form-check-label">@perm.Name</label>
                    </div>
                }
            }
            <button type="submit" class="btn btn-primary mt-3">Guardar permisos</button>
        </form>
    </div>
    <div class="col-md-4">
        <h5>Aplicar plantilla</h5>
        <form asp-action="ApplyTemplate" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="userId" value="@Model.UserId" />
            <select name="templateId" class="form-control"
                    onchange="this.form.submit()">
                <option value="">-- Seleccione plantilla --</option>
                @foreach (var template in Model.Templates)
                {
                    <option value="@template.Id">@template.Name</option>
                }
            </select>
            <small class="form-text text-muted">
                Al aplicar una plantilla se reemplazarán todos los permisos actuales.
            </small>
        </form>
    </div>
</div>

<a asp-action="Index" class="btn btn-secondary mt-3">Volver al listado</a>