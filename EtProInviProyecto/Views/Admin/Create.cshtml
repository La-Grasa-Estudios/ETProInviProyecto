@using EtPro.Models
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@model CreateUserViewModel

@{
    ViewData["Title"] = "Registro de Nuevo Usuario";
    Layout = "_AdminLayout";
}

<div class="container mt-4">
    <div class="card shadow-sm border-0" style="max-width: 800px; margin: auto;">
        <!-- Encabezado Institucional -->
        <div class="card-header bg-white border-bottom-0 pt-3">
            <div class="d-flex align-items-center">
                <div style="width: 4px; height: 24px; background-color: #e31e24; margin-right: 10px;"></div>
                <h4 class="mb-0 text-dark fw-bold">@ViewData["Title"]</h4>
            </div>
            <p class="text-muted small mb-0 ms-3">Complete los datos para otorgar acceso al sistema.</p>
            <hr class="mt-3 mb-0" style="opacity: 0.1;">
        </div>

        <div class="card-body p-4">
            <form asp-action="Create" method="post" id="createUserForm">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="alert alert-danger p-2 small border-0 mb-4"></div>

                <div class="row g-3">
                    <!-- Sección de Identificación -->
                    <div class="col-md-6">
                        <label asp-for="UserName" class="form-label fw-bold small text-uppercase text-muted">Nombre de Usuario</label>
                        <div class="input-group input-group-sm">
                            <span class="input-group-text bg-light border-end-0"><i class="bi bi-person-fill"></i></span>
                            <input asp-for="UserName" class="form-control border-start-0" placeholder="Ej: nromero" required />
                        </div>
                        <span asp-validation-for="UserName" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="DepartmentID" class="form-label fw-bold small text-uppercase text-muted">Departamento Asignado</label>
                        <select asp-for="DepartmentID" class="form-select form-select-sm"
                                asp-items="@(ViewBag.Departments as SelectList)">
                            <option value="">-- Sin departamento --</option>
                        </select>
                        <span asp-validation-for="DepartmentID" class="text-danger small"></span>
                    </div>

                    <hr class="my-4 text-muted opacity-25">

                    <!-- Sección de Seguridad -->
                    <div class="col-md-6">
                        <label asp-for="Password" class="form-label fw-bold small text-uppercase text-muted">Contraseña</label>
                        <div class="input-group input-group-sm">
                            <span class="input-group-text bg-light border-end-0"><i class="bi bi-lock-fill"></i></span>
                            <input asp-for="Password" class="form-control border-start-0" type="password" id="Password" required />
                        </div>
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="ConfirmPassword" class="form-label fw-bold small text-uppercase text-muted">Confirmar Contraseña</label>
                        <div class="input-group input-group-sm">
                            <span class="input-group-text bg-light border-end-0"><i class="bi bi-shield-lock-fill"></i></span>
                            <input asp-for="ConfirmPassword" class="form-control border-start-0" type="password" id="ConfirmPassword" required />
                        </div>
                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>
                </div>

                <!-- Footer de Acciones -->
                <div class="d-flex justify-content-between align-items-center mt-5 pt-3 border-top">
                    <a asp-action="Index" class="btn btn-sm btn-light border px-4">
                        <i class="bi bi-x-circle me-1"></i> Cancelar
                    </a>
                    <button type="submit" class="btn btn-sm px-5 text-white shadow-sm" style="background-color: #004d26; border: none;">
                        <i class="bi bi-person-plus-fill me-1"></i> Crear Usuario
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <!-- SweetAlert2 CDN -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <!-- Bootstrap Icons CDN -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <script>
        document.addEventListener('DOMContentLoaded', function () {
        const form = document.getElementById('createUserForm');

        form.addEventListener('submit', function (e) {
        // Si el formulario no es válido según HTML5 (required, etc), dejamos que el navegador actúe
        if (!form.checkValidity()) {
        return;
        }

        e.preventDefault(); // Detenemos el envío para mostrar SweetAlert

        const userName = document.getElementById('UserName').value;

        Swal.fire({
        title: '¿Confirmar nuevo registro?',
        text: `Se creará el acceso para el usuario: ${userName}`,
        icon: 'question',
        showCancelButton: true,
        confirmButtonColor: '#004d26', // Verde institucional
        cancelButtonColor: '#6c757d',
        confirmButtonText: 'Sí, crear usuario',
        cancelButtonText: 'Revisar datos',
        reverseButtons: true
        }).then((result) => {
        if (result.isConfirmed) {
        // Mostrar estado de carga
        Swal.fire({
        title: 'Procesando...',
        html: 'Registrando credenciales en el sistema',
        allowOutsideClick: false,
        didOpen: () => {
        Swal.showLoading();
        }
        });
        form.submit();
        }
        });
        });
        });
    </script>

    <style>
        body {
        background-color: #f4f6f9;
        }

        .form-label {
        font-size: 0.75rem;
        margin-bottom: 0.4rem;
        }

        .form-control:focus, .form-select:focus {
        border-color: #004d26;
        box-shadow: 0 0 0 0.2rem rgba(0, 77, 38, 0.15);
        }

        .input-group-text {
        color: #6c757d;
        }
    </style>
}