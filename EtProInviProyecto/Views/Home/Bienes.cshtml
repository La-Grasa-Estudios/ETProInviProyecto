@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@model EtProInviProyecto.Models.BienesRegistradosViewModel;
@{
    Layout = "_AdminLayout";
    ViewData["PageName"] = "Bienes Registrados";
    ViewData["PageDescription"] = "Control y consulta de los bienes institucionales registrados en el sistema";
}

<link rel="stylesheet" href="~/css/bienes.css" asp-append-version="true" />

<div class="main-container">
    <div class="actions-container">
        @if (User.HasClaim("Permiso", "Bienes.Crear"))
        {
            <div class="stylized-button">
                <button onclick="window.location.href='/Movements/SolicitarIncorporacion'">Incorporar bien</button>
            </div>
        }
        @if (User.HasClaim("Permiso", "Bienes.Desincorporar"))
        {
            <div class="stylized-button-red btn-spaced">
                <button onclick="window.location.href='/Movements/SolicitarDesincorporacion'">
                    Solicitar Desincorporación
                </button>
            </div>
        }
        @if (User.HasClaim("Permiso", "Movimientos.SolicitarTraspaso"))
        {
            <div class="stylized-button btn-spaced">
                <button onclick="window.location.href='/Movements/SolicitarTraspaso'">
                    Solicitar Traspaso
                </button>
            </div>
        }
        @if (User.HasClaim("Permiso", "Historial.VerPropios") || User.HasClaim("Permiso", "Historial.VerTodos"))
        {
            <div class="stylized-button btn-spaced">
                <button onclick="window.location.href='/Movements/HistorialTraspasos'">
                    Historial de Traspasos
                </button>
            </div>
        }
        @if (User.HasClaim("Permiso", "Movimientos.AprobarTraspaso") || User.HasClaim("Permiso", "Movimientos.AprobarDesincorporacion") || User.HasClaim("Permiso", "Movimientos.AprobarIncorporacion"))
        {
            <div class="dropdown btn-spaced">
                <button class="btn-approve-dropdown dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                    Aprobar
                </button>
                <ul class="dropdown-menu">
                    @if (User.HasClaim("Permiso", "Movimientos.AprobarTraspaso"))
                    {
                        <li><a class="dropdown-item" asp-controller="Movements" asp-action="PendientesTraspaso">Traspasos pendientes</a></li>
                    }
                    @if (User.HasClaim("Permiso", "Movimientos.AprobarDesincorporacion"))
                    {
                        <li><a class="dropdown-item" asp-controller="Movements" asp-action="PendientesDesincorporacion">Desincorporaciones pendientes</a></li>
                    }
                    @if (User.HasClaim("Permiso", "Movimientos.AprobarIncorporacion"))
                    {
                        <li><a class="dropdown-item" asp-controller="Movements" asp-action="PendientesIncorporacion">Incorporaciones pendientes</a></li>
                    }
                </ul>
            </div>
        }
        @if (User.HasClaim("Permiso", "Reportes.VerPropios") || User.HasClaim("Permiso", "Reportes.VerTodos"))
        {
            <div class="dropdown btn-spaced">
                <button class="btn-approve-dropdown dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                    Reportes
                </button>
                <ul class="dropdown-menu">
                    <li><a class="dropdown-item" asp-controller="Reportes" asp-action="InventarioPorDepartamento">Inventario por Departamento</a></li>
                    <li><a class="dropdown-item" asp-controller="Reportes" asp-action="Movimientos">Movimientos</a></li>
                    <li><a class="dropdown-item" asp-controller="Reportes" asp-action="BienesDesincorporados">Bienes Desincorporados</a></li>
                    <li><a class="dropdown-item" asp-controller="Reportes" asp-action="EstadoInventario">Estado del Inventario</a></li>
                </ul>
            </div>
        }
    </div>
    <div class="info-content">
        <div class="inventory-stats-container green">
            <div class="inventory-bubble"></div>
            <div class="inventory-stat">
                <h3>@Model.TotalBienes</h3>
                <span id="totalBienes" data-id="@Model.TotalBienes">Total de bienes</span>
            </div>
        </div>
        <div class="inventory-stats-container white">
            <div class="inventory-bubble"></div>
            <div class="inventory-stat">
                <h3>@Model.TotalActivos</h3>
                <span>Bienes activos</span>
            </div>
        </div>
        <div class="inventory-stats-container red">
            <div class="inventory-bubble"></div>
            <div class="inventory-stat">
                <h3>@Model.TotalMantenimiento</h3>
                <span>En mantenimiento</span>
            </div>
        </div>
        <div class="inventory-stats-container white">
            <div class="inventory-bubble"></div>
            <div class="inventory-stat">
                <h3>@Model.TotalDesincorporados</h3>
                <span>Desincorporados</span>
            </div>
        </div>
        <div class="item-container span4">
            <div class="item-header">
                <span><b>Filtros de búsqueda</b></span>
            </div>
            <div class="search-container">
                <div class="search-filter-container">
                    <div class="filter-container">
                        <span><b>Grupo</b></span>
                        <div class="input-container">
                            <input type="text" id="filtroGrupo" placeholder="Grupo" />
                        </div>
                    </div>
                    <div class="filter-container">
                        <span><b>Subgrupo</b></span>
                        <div class="input-container">
                            <input type="text" id="filtroSubgrupo" placeholder="Subgrupo" />
                        </div>
                    </div>
                    <div class="filter-container">
                        <span><b>Sección</b></span>
                        <div class="input-container">
                            <input type="text" id="filtroSeccion" placeholder="Sección" />
                        </div>
                    </div>
                    <div class="filter-container">
                        <span><b>Nº de identificación</b></span>
                        <div class="input-container">
                            <input type="text" id="filtroCodigo" placeholder="Buscar por código" />
                        </div>
                    </div>
                    <div class="filter-container">
                        <span><b>Nombre / Descripción</b></span>
                        <div class="input-container input-group-text">
                            <input type="text" id="filtroDescripcion" placeholder="Buscar por nombre o descripción" />
                        </div>
                    </div>
                    <div class="filter-container">
                        <span><b>Departamento</b></span>
                        <div class="input-container">
                            <select id="filtroDepartamento" class="form-select form-select-sm">
                                <option value="">-- Todos --</option>
                                @if (ViewBag.DepartmentsList != null)
                                {
                                    @foreach (var dept in ViewBag.DepartmentsList)
                                    {
                                        <option value="@dept.ID">@dept.Name</option>
                                    }
                                }
                            </select>
                        </div>
                    </div>
                    <div class="filter-container">
                        <span><b>Responsable</b></span>
                        <div class="input-container">
                            <select id="filtroResponsable" class="form-select form-select-sm">
                                <option value="">-- Todos --</option>
                                @if (ViewBag.ManagersList != null)
                                {
                                    @foreach (var manager in ViewBag.ManagersList)
                                    {
                                        <option value="@manager.ID">@manager.FullName</option>
                                    }
                                }
                            </select>
                        </div>
                    </div>
                    <div class="filter-container">
                        <span><b>Fecha de registro</b></span>
                        <div class="input-container" style="display: flex; gap: 5px;">
                            <input type="date" id="filtroFechaDesde" class="form-control form-control-sm" />
                            <input type="date" id="filtroFechaHasta" class="form-control form-control-sm" />
                        </div>
                    </div>
                    <div class="filter-container span4 search-form">
                        <span class="invisible">Padding</span>
                        <div class="filter-button-container">
                            <a id="limpiarFiltros" style="cursor:pointer;"><b>Limpiar Filtros</b></a>
                            <div class="search-button" id="btnBuscar">
                                <img src="~/imagenes/search-icon.png" alt="Búsqueda" class="search-icon" />
                                <button type="button">Buscar</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="item-container span4 table-container">
            <div class="item-header">
                <span><b>Listado de bienes</b></span>
            </div>
            <table class="custom-inventory-table">
                <thead>
                    <tr>
                        <th>Grupo</th>
                        <th>Subgrupo</th>
                        <th>Sección</th>
                        <th>Nº de identificación</th>
                        <th>Marca</th>
                        <th>Nombre</th>
                        <th>Valor Total (Bs)</th>
                    </tr>
                </thead>
                <tbody id="inventoryTable"></tbody>
            </table>
            <div class="d-flex justify-content-between align-items-center mt-3 p-2 bg-white border-top">
                <div class="text-secondary" id="infoPaginacion">
                    Mostrando <span id="rangoInicio">0</span> a <span id="rangoFin">0</span> de <span id="totalDisplay">0</span> registros
                </div>
                <div class="d-flex align-items-center gap-4">
                    <div class="d-flex align-items-center gap-2">
                        <span class="text-secondary small">Filas por página:</span>
                        <select id="selectResultados" class="form-select form-select-sm" style="width: 70px;" onchange="cambiarCantidad()">
                            <option value="10">10</option>
                            <option value="20">20</option>
                            <option value="50">50</option>
                        </select>
                    </div>
                    <nav aria-label="Navegación">
                        <ul class="pagination pagination-sm mb-0" id="paginacionLista"></ul>
                    </nav>
                </div>
            </div>
        </div>
    </div>
</div>
<script src="~/js/bienes.js?v=1.4"></script>
@if (TempData["Success"] != null)
{
    <script>
        document.addEventListener('DOMContentLoaded', () =>
        {
            Swal.fire({
                title: 'Correcto',
                text: 'Bien actualizado correctamente!',
                icon: 'success',
                confirmButtonText: 'Continuar',
                theme: 'auto'
            })
        });
    </script>
}