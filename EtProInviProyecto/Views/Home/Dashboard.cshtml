@model EtProInviProyecto.Models.BienesRegistradosViewModel;
@{
    Layout = "_AdminLayout";
    ViewData["PageName"] = "Inicio";
    ViewData["PageDescription"] = "Resumen general del inventario";
}
<link rel="stylesheet" href="~/css/dashboard.css" asp-append-version="true" />

<div class="dashboard-container">

    <div class="info-container">
        <div class="dashboard-info" style="background-color: green;">
            <div class="dashboard-icon">
                <div class="dashboard-icon-bg"></div>
            </div>
            <div class="dashboard-data">
                <h5 class="dashboard-info-title">
                    @if (User.HasClaim("Permiso", "Bienes.VerTodos"))
                    {
                        <text>Total de bienes global</text>
                    }
                    else
                    {
                        <text>Bienes en mi departamento</text>
                    }
                </h5>
                <h1 class="dashboard-number">@Model.TotalBienes</h1>
                <h6>Todos los bienes registrados</h6>
            </div>
        </div>

        <div class="dashboard-info" style="background-color: white; color: black;">
            <div class="dashboard-icon">
                <div class="dashboard-icon-bg" style="background-color: lightgray;"></div>
            </div>
            <div class="dashboard-data">
                <h5 class="dashboard-info-title">Bienes activos</h5>
                <h1 class="dashboard-number">@Model.TotalActivos</h1>
                <h6>En operación</h6>
            </div>
        </div>

        <div class="dashboard-info" style="background-color: orange;">
            <div class="dashboard-icon">
                <div class="dashboard-icon-bg"></div>
            </div>
            <div class="dashboard-data">
                <h5 class="dashboard-info-title">En traspaso</h5>
                <h1 class="dashboard-number">@Model.TotalMantenimiento</h1>
                <h6>Movimientos registrados</h6>
            </div>
        </div>

        <div class="dashboard-info" style="background-color: red;">
            <div class="dashboard-icon">
                <div class="dashboard-icon-bg"></div>
            </div>
            <div class="dashboard-data">
                <h5 class="dashboard-info-title">Desincorporados</h5>
                <h1 class="dashboard-number">@Model.TotalDesincorporados</h1>
                <h6>Bienes dados de baja</h6>
            </div>
        </div>

        @if (User.HasClaim("Permiso", "Movimientos.AprobarTraspaso") ||
                User.HasClaim("Permiso", "Movimientos.AprobarDesincorporacion") ||
                User.HasClaim("Permiso", "Movimientos.AprobarIncorporacion"))
        {
            <div class="dashboard-info" style="background-color: #f39c12; color: white;">
                <div class="dashboard-icon">
                    <div class="dashboard-icon-bg"></div>
                </div>
                <div class="dashboard-data">
                    <h5 class="dashboard-info-title">Solicitudes pendientes</h5>
                    <h1 class="dashboard-number">@Model.SolicitudesPendientes</h1>
                    <h6>Por aprobar</h6>
                </div>
            </div>
        }

        @if (Model.CustodiosACargo > 0 && User.HasClaim("Permiso", "Bienes.Editar") && !User.HasClaim("Permiso", "Admin.Usuarios"))
        {
            <div class="dashboard-info" style="background-color: #007bff; color: white;">
                <div class="dashboard-icon">
                    <div class="dashboard-icon-bg"></div>
                </div>
                <div class="dashboard-data">
                    <h5 class="dashboard-info-title">Custodios a mi cargo</h5>
                    <h1 class="dashboard-number">@Model.CustodiosACargo</h1>
                    <h6>Responsables de inventario</h6>
                </div>
            </div>
        }

        @if (!string.IsNullOrEmpty(Model.GerenteEncargado) && User.HasClaim("Permiso", "Inventario.Verificar") && !User.HasClaim("Permiso", "Admin.Usuarios"))
        {
            <div class="dashboard-info" style="background-color: #6c757d; color: white;">
                <div class="dashboard-icon">
                    <div class="dashboard-icon-bg"></div>
                </div>
                <div class="dashboard-data">
                    <h5 class="dashboard-info-title">Mi Gerente</h5>
                    <h1 class="dashboard-number" style="font-size: 1.5rem;">@Model.GerenteEncargado</h1>
                    <h6>Supervisor directo</h6>
                </div>
            </div>
        }
    </div>

    <div class="dashboard-bottom-section" style="display: flex; flex-wrap: wrap; gap: 20px; margin-top: 30px; width: 100%;">

        <div class="graph-container" style="flex: 1; min-width: 300px;">
            <div class="graph-header">
                <span><b>Estado del Inventario</b></span>
            </div>
            <div class="card-body">
                <div class="chart-container">
                    <canvas id="inventoryChart"></canvas>
                    <div class="chart-center-text">
                        <span class="total-number">@Model.TotalBienes.ToString("N0")</span>
                        <span class="total-label">Total</span>
                    </div>
                </div>
                <div class="legend-container">
                    <div class="legend-item">
                        <span class="dot green"></span>
                        <span class="label">Activos</span>
                        <span class="value">@Model.TotalActivos.ToString("N0") (@((Model.TotalBienes > 0 ? (Model.TotalActivos / (float)Model.TotalBienes) : 0).ToString("P1")))</span>
                    </div>
                    <div class="legend-item">
                        <span class="dot orange"></span>
                        <span class="label">En Traspaso</span>
                        <span class="value">@Model.TotalMantenimiento.ToString("N0") (@((Model.TotalBienes > 0 ? (Model.TotalMantenimiento / (float)Model.TotalBienes) : 0).ToString("P1")))</span>
                    </div>
                    <div class="legend-item">
                        <span class="dot red"></span>
                        <span class="label">Desincorporados</span>
                        <span class="value">@Model.TotalDesincorporados.ToString("N0") (@((Model.TotalBienes > 0 ? (Model.TotalDesincorporados / (float)Model.TotalBienes) : 0).ToString("P1")))</span>
                    </div>
                </div>
            </div>
        </div>

        @if (Model.MovimientosRecientes != null && Model.MovimientosRecientes.Any())
        {
            <div class="graph-container" style="flex: 2; min-width: 400px;">
                <div class="graph-header">
                    <span><b>Últimos Movimientos</b></span>
                </div>
                <div class="card-body" style="overflow-x: auto;">
                    <table class="custom-inventory-table" style="width: 100%;">
                        <thead>
                            <tr>
                                <th>Fecha</th>
                                <th>Tipo</th>
                                <th>Bien</th>
                                <th>Origen</th>
                                <th>Destino</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var mov in Model.MovimientosRecientes)
                            {
                                <tr>
                                    <td>@mov.FechaAprobacion?.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>@mov.Type</td>
                                    <td>@mov.Bien?.NumeroIdentificacion</td>
                                    <td>@mov.OriginDepartment?.Name</td>
                                    <td>@mov.DestinationDepartment?.Name</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
        else
        {
            <div class="graph-container" style="flex: 2; min-width: 400px;">
                <div class="graph-header">
                    <span><b>Últimos Movimientos</b></span>
                </div>
                <div class="card-body text-center py-3 text-muted">
                    No hay movimientos recientes.
                </div>
            </div>
        }

    </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    const ctx = document.getElementById('inventoryChart').getContext('2d');
    const inventoryChart = new Chart(ctx, {
        type: 'doughnut',
        data: {
            datasets: [{
                data: [@Model.TotalActivos, @Model.TotalMantenimiento, @Model.TotalDesincorporados],
                backgroundColor: ['#1a7a44', '#f39c12', '#bdc3c7'],
                borderWidth: 0,
                cutout: '65%'
            }]
        },
        options: {
            responsive: true,
            plugins: {
                legend: { display: false }
            }
        }
    });
</script>