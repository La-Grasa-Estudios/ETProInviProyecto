@model EtPro.Models.ReporteEstadoInventarioViewModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Estado del Inventario</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            color: #333;
        }

        .header {
            border-bottom: 2px solid #e31e24;
            padding-bottom: 10px;
            margin-bottom: 20px;
        }

        .logo {
            width: 100px;
        }

        table {
            width: 300px;
            border-collapse: collapse;
        }

        th {
            background-color: #004d26;
            color: white;
            padding: 8px;
            text-align: left;
        }

        td {
            padding: 8px;
            border-bottom: 1px solid #ddd;
        }
    </style>
</head>
<body>
    <div class="header">
        <img class="logo" src="@ViewBag.LogoPath" alt="Logo" />
        <h1>Estado del Inventario</h1>
    </div>
    <table>
        <tr>
            <th>Total de bienes</th>
            <td>@Model.TotalBienes</td>
        </tr>
        <tr>
            <th>Bienes activos</th>
            <td>@Model.TotalActivos</td>
        </tr>
        <tr>
            <th>En mantenimiento / traspaso</th>
            <td>@Model.TotalMantenimiento</td>
        </tr>
        <tr>
            <th>Bienes desincorporados</th>
            <td>@Model.TotalDesincorporados</td>
        </tr>
    </table>
</body>
</html>