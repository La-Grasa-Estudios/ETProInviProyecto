@using EtPro.Models
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@model IEnumerable<BienMueble>
@{
    ViewData["Title"] = "Reporte de Inventario";
    Layout = null;
    bool filtroAplicado = (bool)(ViewBag.FiltroAplicado ?? false);
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Gestión de Bienes</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/bienes.css" asp-append-version="true" />
</head>
<body>
    <div class="container mt-4">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-white border-bottom-0 pt-3">
                <div class="d-flex align-items-center">
                    <div style="width: 4px; height: 24px; background-color: #e31e24; margin-right: 10px;"></div>
                    <h4 class="mb-0 text-dark fw-bold">@ViewData["Title"]</h4>
                </div>
                <hr class="mt-3 mb-0" style="opacity: 0.1;">
            </div>

            <div class="card-body p-4">
                <form method="post" id="reporteForm">
                    <div class="row g-3">
                        <div class="col-md-3">
                            <label class="form-label fw-semibold small text-uppercase text-secondary">Departamento</label>
                            @if (filtroAplicado)
                            {
                                @Html.DropDownList("departamentoId", (SelectList)ViewBag.Departments, "-- Todos --", new { @class = "form-select form-select-sm filtro-auto" })
                            }
                            else
                            {
                                @Html.DropDownList("departamentoId", (SelectList)ViewBag.Departments, "-- Seleccione un departamento --", new { @class = "form-select form-select-sm filtro-auto" })
                            }
                        </div>
                    </div>
                </form>

                @if (Model != null && Model.Any())
                {
                    var deptNames = ViewBag.DepartmentNames as Dictionary<int, string>;
                    <div class="table-responsive mt-4">
                        <table class="table table-hover align-middle mb-0" style="font-size: 0.85rem;">
                            <thead class="table-light">
                                <tr>
                                    <th class="text-uppercase small text-secondary">Nº ID</th>
                                    <th class="text-uppercase small text-secondary">Nombre</th>
                                    <th class="text-uppercase small text-secondary">Marca</th>
                                    <th class="text-uppercase small text-secondary">Departamento</th>
                                    <th class="text-uppercase small text-secondary">Valor</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var b in Model)
                                {
                                    <tr>
                                        <td>@b.NumeroIdentificacion</td>
                                        <td>@b.Nombre</td>
                                        <td>@b.Marca</td>
                                        <td>
                                            @if (deptNames != null && deptNames.ContainsKey(b.DependenciaID))
                                            {
                                                @deptNames[b.DependenciaID]
                                            }
                                            else
                                            {
                                                @($"Dept. {b.DependenciaID}")
                                            }
                                        </td>
                                        <td>@b.ValorUnitario.ToString("C")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <form method="post" class="mt-4 text-end">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="departamentoId" value="@ViewBag.DepartamentoId" />
                        <input type="hidden" name="modo" value="pdf" />
                        <button type="submit" class="btn btn-dark btn-sm px-4" style="background-color: #004d26; border: none;">
                            <i class="bi bi-file-earmark-pdf me-1"></i> Descargar PDF
                        </button>
                    </form>
                }
                else if (filtroAplicado)
                {
                    <p class="mt-4 text-muted text-center py-3">No se encontraron bienes con los filtros seleccionados.</p>
                }
            </div>
        </div>
    </div>

    <style>
        .form-control:focus, .form-select:focus {
            border-color: #004d26;
            box-shadow: 0 0 0 0.2rem rgba(0, 77, 38, 0.1);
        }
    </style>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            document.querySelectorAll('.filtro-auto').forEach(el => {
                el.addEventListener('change', function() {
                    document.getElementById('reporteForm').submit();
                });
            });
        });
    </script>
</body>
</html>