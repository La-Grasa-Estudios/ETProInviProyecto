@using EtPro.Models
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@model ReporteEstadoInventarioViewModel
@{
    ViewData["Title"] = "Estado del Inventario";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Gestión de Bienes</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/bienes.css" asp-append-version="true" />
</head>
<body>
    <div class="container mt-4">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-white border-bottom-0 pt-3">
                <div class="d-flex align-items-center">
                    <div style="width: 4px; height: 24px; background-color: #e31e24; margin-right: 10px;"></div>
                    <h4 class="mb-0 text-dark fw-bold">@ViewData["Title"]</h4>
                </div>
                <hr class="mt-3 mb-0" style="opacity: 0.1;">
            </div>

            <div class="card-body p-4">
                <div class="table-responsive mt-4">
                    <table class="table table-hover align-middle mb-0" style="max-width: 500px; font-size: 0.85rem;">
                        <thead class="table-light">
                            <tr>
                                <th class="text-uppercase small text-secondary">Concepto</th>
                                <th class="text-uppercase small text-secondary text-end">Cantidad</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>Total de bienes</td>
                                <td class="text-end fw-semibold">@Model.TotalBienes</td>
                            </tr>
                            <tr>
                                <td>Bienes activos</td>
                                <td class="text-end fw-semibold">@Model.TotalActivos</td>
                            </tr>
                            <tr>
                                <td>En mantenimiento / traspaso</td>
                                <td class="text-end fw-semibold">@Model.TotalMantenimiento</td>
                            </tr>
                            <tr>
                                <td>Bienes desincorporados</td>
                                <td class="text-end fw-semibold">@Model.TotalDesincorporados</td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <form method="post" class="mt-4 text-end">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="modo" value="pdf" />
                    <button type="submit" class="btn btn-dark btn-sm px-4" style="background-color: #004d26; border: none;">
                        <i class="bi bi-file-earmark-pdf me-1"></i> Descargar PDF
                    </button>
                </form>
            </div>
        </div>
    </div>

    <style>
        .form-control:focus, .form-select:focus {
            border-color: #004d26;
            box-shadow: 0 0 0 0.2rem rgba(0, 77, 38, 0.1);
        }
    </style>
</body>
</html>