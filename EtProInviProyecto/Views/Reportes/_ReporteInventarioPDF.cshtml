@using EtPro.Models
@model IEnumerable<BienMueble>
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Inventario</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            color: #333;
        }

        .header {
            border-bottom: 2px solid #e31e24;
            padding-bottom: 10px;
            margin-bottom: 20px;
        }

        .logo {
            width: 100px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        th {
            background-color: #004d26;
            color: white;
            padding: 8px;
            text-align: left;
        }

        td {
            padding: 8px;
            border-bottom: 1px solid #ddd;
        }
    </style>
</head>
<body>
    <div class="header">
        <img class="logo" src="@ViewBag.LogoPath" alt="Logo" />
        <h1>Reporte de Inventario</h1>
    </div>
    <table>
        <thead>
            <tr>
                <th>Nº Identificación</th>
                <th>Nombre</th>
                <th>Marca</th>
                <th>Departamento</th>
                <th>Valor</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.NumeroIdentificacion</td>
                    <td>@item.Nombre</td>
                    <td>@item.Marca</td>
                    <td>@item.DependenciaID</td>
                    <td>@item.ValorUnitario.ToString("C")</td>
                </tr>
            }
        </tbody>
    </table>
</body>
</html>