@using EtPro.Models
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@model IEnumerable<BienMueble>
@{
    ViewData["Title"] = "Generar Etiquetas";
    
    string userAgent = Context.Request.Headers["User-Agent"].ToString().ToLower();
    bool isMobile = userAgent.Contains("mobi") || userAgent.Contains("android") || userAgent.Contains("iphone") || userAgent.Contains("ipad");

    Layout = isMobile ? null : "_AdminLayout";
    
    int[] selectedIds = ViewBag.SelectedIds as int[] ?? new int[0];
}

@if (isMobile)
{
    @Html.Raw("<!DOCTYPE html>\n<html lang=\"es\">\n<head>")
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" />
    @Html.Raw("</head>\n<body style=\"background-color: #f4f6f9; padding-top: 15px;\">")
}

<div class="container mt-4">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-white border-bottom-0 pt-3 pb-2">
            <div class="d-flex flex-column flex-sm-row align-items-sm-center justify-content-between gap-3">
                <div class="d-flex align-items-center">
                    <div style="width: 4px; height: 24px; background-color: #e31e24; margin-right: 10px; flex-shrink: 0;"></div>
                    <h4 class="mb-0 text-dark fw-bold fs-5 fs-sm-4 text-truncate">@ViewData["Title"]</h4>
                </div>
                <div class="d-grid d-sm-block">
                    <button type="button" id="btnScan" class="btn btn-dark btn-sm px-4" style="background-color: #004d26; border: none;">
                        <i class="bi bi-qr-code-scan me-1"></i> Escanear QR
                    </button>
                </div>
            </div>
            <hr class="mt-3 mb-0" style="opacity: 0.1;">
        </div>

        <div class="card-body p-3 p-md-4">
            <div id="reader" style="width: 100%; max-width: 400px; margin: 0 auto 1.5rem; display: none;"></div>
            <p id="scanMessage" class="text-muted small text-center" style="display: none;">Apunta la cámara hacia una etiqueta</p>

            <form method="post" asp-action="GenerarVistaPrevia" id="vistaPreviaForm">
                @Html.AntiForgeryToken()
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="table-light text-nowrap">
                            <tr>
                                <th style="width: 40px;"><input type="checkbox" id="selectAll" /></th>
                                <th>Nº Identificación</th>
                                <th>Nombre</th>
                                <th>Departamento</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>
                                        <input type="checkbox" name="bienesIds" value="@item.ID" class="bien-check" 
                                               checked="@(selectedIds.Contains(item.ID))" />
                                    </td>
                                    <td>@item.NumeroIdentificacion</td>
                                    <td>@item.Nombre</td>
                                    <td>@(ViewBag.Departments != null ? ((List<Department>)ViewBag.Departments).FirstOrDefault(d => d.ID == item.DependenciaID)?.Name : "")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </form>

            <form method="post" asp-action="GenerarPDF" id="pdfForm" style="display:none;">
                @Html.AntiForgeryToken()
                <div id="pdfCheckboxes"></div>
            </form>

            <div class="d-grid gap-2 d-sm-flex justify-content-sm-end mt-4">
                <button type="submit" form="vistaPreviaForm" class="btn btn-dark btn-sm px-4" style="background-color: #004d26; border: none;">
                    <i class="bi bi-eye me-1"></i> Vista previa
                </button>
                <button type="button" id="btnGenerarPDF" class="btn btn-dark btn-sm px-4" style="background-color: #004d26; border: none;">
                    <i class="bi bi-file-earmark-pdf me-1"></i> Descargar PDF
                </button>
            </div>
        </div>
    </div>
</div>

<script src="~/lib/qrcodedecoder/html5-qrcode.min.js"></script>
<script>
    document.getElementById('selectAll').addEventListener('change', function() {
        const checkboxes = document.querySelectorAll('.bien-check');
        checkboxes.forEach(cb => cb.checked = this.checked);
    });

    document.getElementById('btnGenerarPDF').addEventListener('click', function() {
        const pdfContainer = document.getElementById('pdfCheckboxes');
        pdfContainer.innerHTML = '';
        const marcados = document.querySelectorAll('.bien-check:checked');
        marcados.forEach(cb => {
            const input = document.createElement('input');
            input.type = 'hidden';
            input.name = 'bienesIds';
            input.value = cb.value;
            pdfContainer.appendChild(input);
        });
        document.getElementById('pdfForm').submit();
    });

    let html5Qrcode;
    let scanning = false;
    const reader = document.getElementById('reader');
    const scanBtn = document.getElementById('btnScan');
    const scanMsg = document.getElementById('scanMessage');

    scanBtn.addEventListener('click', function () {
        if (scanning) {
            stopScan();
        } else {
            startScan();
        }
    });

    function startScan() {
        scanning = true;
        reader.style.display = 'block';
        scanMsg.style.display = 'block';
        scanMsg.innerText = 'Apunta la cámara hacia una etiqueta';
        scanBtn.innerHTML = '<i class="bi bi-stop-circle me-1"></i> Detener escaneo';
        scanBtn.classList.add('btn-danger');
        scanBtn.classList.remove('btn-dark');

        html5Qrcode = new Html5Qrcode("reader");
        html5Qrcode.start(
            { facingMode: "environment" },
            { fps: 10, qrbox: { width: 250, height: 250 } },
            (decodedText) => {
                html5Qrcode.stop().then(() => {
                    if (decodedText.startsWith('http')) {
                        window.location.href = decodedText;
                    }
                });
            },
            (errorMessage) => {}
        ).catch(err => {
            scanMsg.innerText = 'No se pudo acceder a la cámara. Verifica los permisos.';
            stopScan();
        });
    }

    function stopScan() {
        if (html5Qrcode) {
            html5Qrcode.stop().then(() => {
                resetUI();
            }).catch(() => {
                resetUI();
            });
        } else {
            resetUI();
        }
    }

    function resetUI() {
        reader.style.display = 'none';
        scanMsg.style.display = 'none';
        scanning = false;
        scanBtn.innerHTML = '<i class="bi bi-qr-code-scan me-1"></i> Escanear QR';
        scanBtn.classList.remove('btn-danger');
        scanBtn.classList.add('btn-dark');
    }

    window.addEventListener('beforeunload', function () {
        if (html5Qrcode && scanning) {
            html5Qrcode.stop().catch(() => {});
        }
    });
</script>

@if (isMobile)
{
    @Html.Raw("</body>\n</html>")
}
