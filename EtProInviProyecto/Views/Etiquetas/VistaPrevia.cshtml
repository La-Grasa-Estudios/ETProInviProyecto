@using EtPro.Models
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@model List<EtiquetaViewModel>
@{
    ViewData["Title"] = "Vista previa de etiquetas";
    Layout = "_AdminLayout";
}

<style>
    .label-preview {
        background: white;
        border: 2px dashed #333;
        padding: 8px; /* Espacio interno de la etiqueta reducido */
        width: 100%;
        max-width: 380px;
        margin: 0 auto;
        font-family: Arial, sans-serif;
        color: black;
    }

    .label-header {
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 5px; /* Espacio con la caja reducido */
    }

    .label-logo {
        width: 60px;
        margin-right: 10px;
    }

    .label-title {
        font-size: 10px;
        font-weight: bold;
        text-align: center;
        text-transform: uppercase;
        line-height: 1.2;
    }

    .label-box {
        border: 2px solid black;
        text-align: center;
    }

    .label-box-header {
        display: flex;
        border-bottom: 1px solid black;
        font-weight: bold;
        font-size: 12px;
    }

        .label-box-header > div {
            flex: 1;
            padding: 2px; /* Espacio interno reducido */
            border-right: 1px solid black;
        }

            .label-box-header > div:last-child {
                border-right: none;
            }

    .label-qr-body {
        padding: 2px; /* Margen del QR contra la caja reducido al mínimo */
    }

    .label-bienes-text {
        border-top: 1px solid black;
        font-size: 10px;
        font-weight: bold;
        letter-spacing: 3px;
        padding: 2px;
    }

    .label-footer {
        text-align: center;
        font-weight: bold;
        font-size: 12px;
        margin-top: 4px; /* Espacio reducido */
        text-transform: uppercase;
    }
</style>

<div class="container mt-4">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-white border-bottom-0 pt-3">
            <div class="d-flex align-items-center justify-content-between">
                <div class="d-flex align-items-center">
                    <div style="width: 4px; height: 24px; background-color: #e31e24; margin-right: 10px;"></div>
                    <h4 class="mb-0 text-dark fw-bold">@ViewData["Title"]</h4>
                </div>
                <form method="post" asp-action="GenerarPDF">
                    @Html.AntiForgeryToken()
                    @foreach (var e in Model)
                    {
                        <input type="hidden" name="bienesIds" value="@e.BienId" />
                    }
                    <button type="submit" class="btn btn-dark btn-sm px-4" style="background-color: #004d26; border: none;">
                        <i class="bi bi-file-earmark-pdf me-1"></i> Descargar PDF
                    </button>
                </form>
            </div>
            <hr class="mt-3 mb-0" style="opacity: 0.1;">
        </div>
        <div class="card-body p-4 bg-light">
            <div class="row g-4">
                @foreach (var etiqueta in Model)
                {
                    <div class="col-xl-4 col-md-6 col-sm-12">
                        <div class="label-preview">
                            <div class="label-header">
                                <img src="~/imagenes/logo.jpg" class="label-logo" alt="Logo" />
                                <div class="label-title">
                                    EMPRESA TRUJILLANA DE<br />PROYECTOS, INFRAESTRUCTURA Y<br />VIVIENDA S.A
                                </div>
                            </div>

                            <div class="label-box">
                                <div class="label-box-header">
                                    <div>G: @etiqueta.Grupo</div>
                                    <div>SG: @etiqueta.Subgrupo</div>
                                    <div>COD: @etiqueta.Codigo</div>
                                </div>
                                <div class="label-qr-body">
                                    <img src="data:image/png;base64,@etiqueta.QrBase64" alt="QR" style="width: 200px; height: 200px;" />
                                </div>
                                <div class="label-bienes-text">BIENES</div>
                            </div>

                            <div class="label-footer">
                                @etiqueta.Descripcion | @etiqueta.Anio
                            </div>
                        </div>
                    </div>
                }
            </div>
            <div class="d-flex justify-content-end gap-2 mt-4">
                <form method="post" asp-action="Index">
                    @Html.AntiForgeryToken()
                    @foreach (var e in Model)
                    {
                        <input type="hidden" name="bienesIds" value="@e.BienId" />
                    }
                    <button type="submit" class="btn btn-light btn-sm px-4 border text-secondary">Volver</button>
                </form>
            </div>
        </div>
    </div>
</div>