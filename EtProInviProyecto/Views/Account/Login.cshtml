@using EtPro.Models
@model LoginViewModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    ViewData["Title"] = "Acceso al Sistema";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ET PROINVI</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
            body {
                background: #f4f6f9;
                height: 100vh;
                display: flex;
                align-items: center;
                justify-content: center;
            }

            .login-card {
                width: 100%;
                max-width: 400px;
                border: none;
                border-radius: 15px;
                box-shadow: 0 10px 25px rgba(0,0,0,0.1);
            }

            .brand-stripe {
                height: 5px;
                width: 100%;
                background: linear-gradient(to right, #004d26 50%, #e31e24 50%);
                border-radius: 15px 15px 0 0;
            }

            .btn-login {
                background-color: #004d26;
                color: white;
                border: none;
                transition: all 0.3s;
            }

                .btn-login:hover {
                    background-color: #00361a;
                    color: white;
                    transform: translateY(-1px);
                }

            .form-control:focus, .form-check-input:focus {
                border-color: #004d26;
                box-shadow: 0 0 0 0.25rem rgba(0, 77, 38, 0.1);
            }

            .form-check-input:checked {
                background-color: #004d26;
                border-color: #004d26;
            }
    </style>
</head>
<body>

    <div class="container">
        <div class="card login-card mx-auto">
            <div class="brand-stripe"></div>
            <div class="card-body p-5">
                <div class="text-center mb-4">
                    <h3 class="fw-bold text-dark">ET PROINVI</h3>
                    <p class="text-muted small">Panel de Gestión de Seguridad</p>
                </div>

                <form asp-action="Login" method="post" id="loginForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />

                    <div class="mb-3">
                        <label asp-for="Username" class="form-label small fw-bold text-muted text-uppercase">Usuario</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0 text-muted"><i class="bi bi-person"></i></span>
                            <input asp-for="Username" class="form-control border-start-0" placeholder="Ingrese su usuario" required />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Password" class="form-label small fw-bold text-muted text-uppercase">Contraseña</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0 text-muted"><i class="bi bi-lock"></i></span>
                            <input asp-for="Password" type="password" class="form-control border-start-0" placeholder="••••••••" required />
                        </div>
                    </div>

                    <div class="form-check mb-4">
                        <input asp-for="RememberMe" type="checkbox" class="form-check-input" />
                        <label asp-for="RememberMe" class="form-check-label small text-muted">Mantener sesión iniciada</label>
                    </div>

                    <div class="d-grid">
                        <button type="submit" class="btn btn-login py-2 fw-bold">
                            INGRESAR <i class="bi bi-box-arrow-in-right ms-2"></i>
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    @if (!ViewData.ModelState.IsValid)
    {
        <script>
            Swal.fire({
            icon: 'error',
            title: 'Error de Acceso',
            text: 'Las credenciales proporcionadas no son válidas.',
            confirmButtonColor: '#e31e24'
            });
        </script>
    }

    <script>
        document.getElementById('loginForm').addEventListener('submit', function() {
        Swal.fire({
        title: 'Autenticando...',
        allowOutsideClick: false,
        didOpen: () => {
        Swal.showLoading();
        }
        });
        });
    </script>

</body>
</html>