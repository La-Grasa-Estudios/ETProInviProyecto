@using EtPro.Models
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@model ChangePasswordViewModel
@{
    ViewData["Title"] = "Cambiar Contraseña";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Gestión de Bienes</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="container mt-4">
        <div class="card shadow-sm border-0" style="max-width: 500px; margin: auto;">
            <div class="card-header bg-white border-bottom-0 pt-3">
                <div class="d-flex align-items-center">
                    <div style="width: 4px; height: 24px; background-color: #e31e24; margin-right: 10px;"></div>
                    <h4 class="mb-0 text-dark fw-bold">@ViewData["Title"]</h4>
                </div>
                <hr class="mt-3 mb-0" style="opacity: 0.1;">
            </div>

            <div class="card-body p-4">
                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger small">
                        @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                        {
                            <p class="mb-0">@error.ErrorMessage</p>
                        }
                    </div>
                }

                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success small">@TempData["Success"]</div>
                }

                <form asp-action="ChangePassword" method="post">
                    @Html.AntiForgeryToken()

                    <div class="form-group mb-3">
                        <label asp-for="CurrentPassword" class="form-label fw-semibold small text-uppercase text-secondary"></label>
                        <input asp-for="CurrentPassword" class="form-control form-control-sm" />
                        <span asp-validation-for="CurrentPassword" class="text-danger small"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="NewPassword" class="form-label fw-semibold small text-uppercase text-secondary"></label>
                        <input asp-for="NewPassword" class="form-control form-control-sm" />
                        <span asp-validation-for="NewPassword" class="text-danger small"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="ConfirmNewPassword" class="form-label fw-semibold small text-uppercase text-secondary"></label>
                        <input asp-for="ConfirmNewPassword" class="form-control form-control-sm" />
                        <span asp-validation-for="ConfirmNewPassword" class="text-danger small"></span>
                    </div>

                    <div class="d-flex justify-content-end gap-2 mt-4 pt-3 border-top">
                        <a href="javascript:history.back()" class="btn btn-light btn-sm px-4 border text-secondary">Cancelar</a>
                        <button type="submit" class="btn btn-dark btn-sm px-4" style="background-color: #004d26; border: none;">
                            <i class="bi bi-key me-1"></i> Cambiar contraseña
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <style>
        .form-control:focus, .form-select:focus {
            border-color: #004d26;
            box-shadow: 0 0 0 0.2rem rgba(0, 77, 38, 0.1);
        }

        .form-label {
            font-size: 0.75rem;
            letter-spacing: 0.5px;
        }
    </style>
</body>
</html>