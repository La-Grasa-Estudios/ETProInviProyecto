@using EtPro.Models
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@model SolicitarDesincorporacionViewModel
@{
    ViewData["Title"] = "Solicitar Desincorporación";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Gestión de Bienes</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="container mt-4">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-white border-bottom-0 pt-3">
                <div class="d-flex align-items-center">
                    <div style="width: 4px; height: 24px; background-color: #e31e24; margin-right: 10px;"></div>
                    <h4 class="mb-0 text-dark fw-bold">@ViewData["Title"]</h4>
                </div>
                <hr class="mt-3 mb-0" style="opacity: 0.1;">
            </div>

            <div class="card-body p-4">
                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger small">
                        @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                        {
                            <p class="mb-0">@error.ErrorMessage</p>
                        }
                    </div>
                }

                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success small">@TempData["Success"]</div>
                }

                <form asp-action="SolicitarDesincorporacion" method="post">
                    @Html.AntiForgeryToken()

                    <div class="row g-3">
                        <div class="col-md-8">
                            <label asp-for="BienId" class="form-label fw-semibold small text-uppercase text-secondary">Bien a desincorporar</label>
                            <select asp-for="BienId" class="form-select form-select-sm"
                                    asp-items="@(ViewBag.Bienes as SelectList)">
                                <option value="">-- Seleccione un bien --</option>
                            </select>
                            <span asp-validation-for="BienId" class="text-danger small"></span>
                        </div>

                        <div class="col-12">
                            <label asp-for="Motivo" class="form-label fw-semibold small text-uppercase text-secondary">Motivo de la desincorporación</label>
                            <textarea asp-for="Motivo" class="form-control form-control-sm" rows="4" placeholder="Explique el motivo de la baja..."></textarea>
                            <span asp-validation-for="Motivo" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="d-flex justify-content-end gap-2 mt-4 pt-3 border-top">
                        <a asp-controller="Home" asp-action="Bienes" class="btn btn-light btn-sm px-4 border text-secondary">Cancelar</a>
                        <button type="submit" class="btn btn-dark btn-sm px-4" style="background-color: #004d26; border: none;">
                            <i class="bi bi-save me-1"></i> Enviar solicitud
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <style>
        .form-control:focus, .form-select:focus {
            border-color: #004d26;
            box-shadow: 0 0 0 0.2rem rgba(0, 77, 38, 0.1);
        }

        .form-label {
            font-size: 0.75rem;
            letter-spacing: 0.5px;
        }
    </style>
</body>
</html>