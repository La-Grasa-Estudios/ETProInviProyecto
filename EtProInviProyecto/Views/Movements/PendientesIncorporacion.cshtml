@using EtPro.Models
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@model IEnumerable<Movement>
@{
    ViewData["Title"] = "Incorporaciones Pendientes";
}

<h2>@ViewData["Title"]</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

@if (!Model.Any())
{
    <p>No hay solicitudes de incorporación pendientes.</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Núm. Identificación</th>
                <th>Nombre</th>
                <th>Departamento</th>
                <th>Solicitante</th>
                <th>Fecha solicitud</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Bien?.NumeroIdentificacion</td>
                    <td>@item.Bien?.Nombre</td>
                    <td>@item.OriginDepartment?.Name</td>
                    <td>@item.UsuarioSolicitante?.UserName</td>
                    <td>@item.FechaSolicitud.ToString("dd/MM/yyyy HH:mm")</td>
                    <td>
                        <form asp-action="AprobarIncorporacion" method="post" style="display:inline;">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@item.Id" />
                            <button type="submit" class="btn btn-sm btn-success">Aprobar</button>
                        </form>
                        <form asp-action="RechazarIncorporacion" method="post" style="display:inline;">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@item.Id" />
                            <button type="submit" class="btn btn-sm btn-danger">Rechazar</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}