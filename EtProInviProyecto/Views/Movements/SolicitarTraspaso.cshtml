@using EtPro.Models
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@model SolicitarTraspasoViewModel
@{
    ViewData["Title"] = "Solicitar Traspaso";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Gestión de Bienes</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/bienes.css" asp-append-version="true" />
</head>
<body>
    <div class="container mt-4">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-white border-bottom-0 pt-3">
                <div class="d-flex align-items-center">
                    <div style="width: 4px; height: 24px; background-color: #e31e24; margin-right: 10px;"></div>
                    <h4 class="mb-0 text-dark fw-bold">@ViewData["Title"]</h4>
                </div>
                <hr class="mt-3 mb-0" style="opacity: 0.1;">
            </div>

            <div class="card-body p-4">
                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger small">
                        @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                        {
                            <p class="mb-0">@error.ErrorMessage</p>
                        }
                    </div>
                }

                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success small">@TempData["Success"]</div>
                }

                <form asp-action="SolicitarTraspaso" method="post">
                    @Html.AntiForgeryToken()

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="BienId" class="form-label fw-semibold small text-uppercase text-secondary">Bien a trasladar</label>
                            <select asp-for="BienId" class="form-select form-select-sm" id="bienSelect"
                                    asp-items="@(ViewBag.Bienes as SelectList)">
                                <option value="">-- Seleccione un bien --</option>
                            </select>
                            <span asp-validation-for="BienId" class="text-danger small"></span>
                            <!-- Contenedor de información del bien (inicialmente oculto) -->
                            <div id="bienInfoContainer" class="mt-3" style="display: none;">
                                <div class="card border-light shadow-sm">
                                    <div class="card-body p-3">
                                        <h6 class="fw-bold text-secondary text-uppercase small">Información del bien seleccionado</h6>
                                        <table class="table table-sm table-borderless mb-0" style="font-size: 0.85rem;">
                                            <tr>
                                                <th class="ps-0 text-muted" style="width: 40%;">Código:</th>
                                                <td id="bienCodigo"></td>
                                            </tr>
                                            <tr>
                                                <th class="ps-0 text-muted">Nombre:</th>
                                                <td id="bienNombre"></td>
                                            </tr>
                                            <tr>
                                                <th class="ps-0 text-muted">Marca:</th>
                                                <td id="bienMarca"></td>
                                            </tr>
                                            <tr>
                                                <th class="ps-0 text-muted">Modelo:</th>
                                                <td id="bienModelo"></td>
                                            </tr>
                                            <tr>
                                                <th class="ps-0 text-muted">Departamento actual:</th>
                                                <td id="bienDepartamento"></td>
                                            </tr>
                                            <tr>
                                                <th class="ps-0 text-muted">Estado:</th>
                                                <td id="bienEstado"></td>
                                            </tr>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="DestinationDepartmentId" class="form-label fw-semibold small text-uppercase text-secondary">Departamento destino</label>
                            <select asp-for="DestinationDepartmentId" class="form-select form-select-sm"
                                    asp-items="@(ViewBag.Departments as SelectList)">
                                <option value="">-- Seleccione destino --</option>
                            </select>
                            <span asp-validation-for="DestinationDepartmentId" class="text-danger small"></span>
                        </div>

                        <div class="col-12">
                            <label asp-for="Motivo" class="form-label fw-semibold small text-uppercase text-secondary">Motivo del traspaso</label>
                            <textarea asp-for="Motivo" class="form-control form-control-sm" rows="4" placeholder="Explique el motivo del traspaso..."></textarea>
                            <span asp-validation-for="Motivo" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="d-flex justify-content-end gap-2 mt-4 pt-3 border-top">
                        <a asp-controller="Home" asp-action="Bienes" class="btn btn-light btn-sm px-4 border text-secondary">Cancelar</a>
                        <button type="submit" class="btn btn-dark btn-sm px-4" style="background-color: #004d26; border: none;">
                            <i class="bi bi-save me-1"></i> Enviar solicitud
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const bienSelect = document.getElementById('bienSelect');
            const infoContainer = document.getElementById('bienInfoContainer');
            const codigo = document.getElementById('bienCodigo');
            const nombre = document.getElementById('bienNombre');
            const marca = document.getElementById('bienMarca');
            const modelo = document.getElementById('bienModelo');
            const departamento = document.getElementById('bienDepartamento');
            const estado = document.getElementById('bienEstado');

            bienSelect.addEventListener('change', async function () {
                const bienId = this.value;
                if (!bienId) {
                    infoContainer.style.display = 'none';
                    return;
                }

                try {
                    const response = await fetch(`/Bienes/ObtenerDatosBien/${bienId}`);
                    if (!response.ok) {
                        throw new Error('Error al obtener los datos del bien.');
                    }
                    const data = await response.json();
                    codigo.textContent = data.numeroIdentificacion || '-';
                    nombre.textContent = data.nombre || '-';
                    marca.textContent = data.marca || '-';
                    modelo.textContent = data.modelo || '-';
                    departamento.textContent = data.departamento || '-';
                    estado.textContent = data.estado || '-';
                    infoContainer.style.display = 'block';
                } catch (error) {
                    console.error(error);
                    infoContainer.style.display = 'none';
                }
            });
        });
    </script>

    <style>
        .form-control:focus, .form-select:focus {
            border-color: #004d26;
            box-shadow: 0 0 0 0.2rem rgba(0, 77, 38, 0.1);
        }

        .form-label {
            font-size: 0.75rem;
            letter-spacing: 0.5px;
        }
    </style>
</body>
</html>