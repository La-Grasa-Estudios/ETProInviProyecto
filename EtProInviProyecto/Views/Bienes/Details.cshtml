@using EtPro.Models;
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@model BienMueble
@{
    ViewData["Title"] = "Detalle del Bien";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Gestión de Bienes</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/bienes.css" asp-append-version="true" />
</head>
<body>
    <div class="container mt-4">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-white border-bottom-0 pt-3">
                <div class="d-flex align-items-center justify-content-between">
                    <div class="d-flex align-items-center">
                        <div style="width: 4px; height: 24px; background-color: #e31e24; margin-right: 10px;"></div>
                        <h4 class="mb-0 text-dark fw-bold">@ViewData["Title"]</h4>
                    </div>
                    <span class="badge @(Model.Activo ? "bg-success" : "bg-danger") px-3 py-2">
                        @(Model.Activo ? "Activo" : "Inactivo")
                    </span>
                </div>
                <hr class="mt-3 mb-0" style="opacity: 0.1;">
            </div>

            <div class="card-body p-4">
                <div class="row g-4">
                    <!-- Columna izquierda -->
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label fw-semibold small text-uppercase text-secondary">Nº de Identificación</label>
                            <p class="fw-bold mb-0">@Model.NumeroIdentificacion</p>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold small text-uppercase text-secondary">Nombre del Bien</label>
                            <p class="mb-0">@Model.Nombre</p>
                        </div>
                        <div class="row mb-3">
                            <div class="col-6">
                                <label class="form-label fw-semibold small text-uppercase text-secondary">Marca</label>
                                <p class="mb-0">@(Model.Marca ?? "—")</p>
                            </div>
                            <div class="col-6">
                                <label class="form-label fw-semibold small text-uppercase text-secondary">Modelo</label>
                                <p class="mb-0">@(Model.Modelo ?? "—")</p>
                            </div>
                        </div>
                        <div class="row mb-3">
                            <div class="col-6">
                                <label class="form-label fw-semibold small text-uppercase text-secondary">Serial</label>
                                <p class="mb-0">@(Model.Serial ?? "—")</p>
                            </div>
                            <div class="col-6">
                                <label class="form-label fw-semibold small text-uppercase text-secondary">Color</label>
                                <p class="mb-0">@(Model.Color ?? "—")</p>
                            </div>
                        </div>
                    </div>

                    <!-- Columna derecha -->
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label fw-semibold small text-uppercase text-secondary">Material</label>
                            <p class="mb-0">@(Model.Material ?? "—")</p>
                        </div>
                        <div class="row mb-3">
                            <div class="col-4">
                                <label class="form-label fw-semibold small text-uppercase text-secondary">Grupo</label>
                                <p class="mb-0">@Model.Grupo</p>
                            </div>
                            <div class="col-4">
                                <label class="form-label fw-semibold small text-uppercase text-secondary">Subgrupo</label>
                                <p class="mb-0">@(Model.Subgrupo ?? "—")</p>
                            </div>
                            <div class="col-4">
                                <label class="form-label fw-semibold small text-uppercase text-secondary">Sección</label>
                                <p class="mb-0">@(Model.Seccion ?? "—")</p>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold small text-uppercase text-secondary">Departamento</label>
                            <p class="mb-0">@(ViewBag.DepartamentoNombre ?? "Sin asignar")</p>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold small text-uppercase text-secondary">Valor Unitario</label>
                            <p class="fw-bold mb-0">@Model.ValorUnitario.ToString("C")</p>
                        </div>
                    </div>
                </div>

                <!-- Observaciones -->
                <div class="mt-3">
                    <label class="form-label fw-semibold small text-uppercase text-secondary">Observaciones Adicionales</label>
                    <p class="mb-0">@(Model.ObservacionesAdicionales ?? "Sin observaciones")</p>
                </div>

                <!-- Botones de acción -->
                <div class="d-flex justify-content-end gap-2 mt-4 pt-3 border-top flex-wrap">
                    @if (User.HasClaim("Permiso", "Bienes.Editar"))
                    {
                        <a asp-action="Edit" asp-route-id="@Model.ID" class="btn btn-dark btn-sm px-4" style="background-color: #004d26; border: none;">
                            <i class="bi bi-pencil me-1"></i> Editar
                        </a>
                    }
                    @if (User.HasClaim("Permiso", "Movimientos.SolicitarTraspaso"))
                    {
                        <a href="/Movements/SolicitarTraspaso?bienId=@Model.ID" class="btn btn-dark btn-sm px-4" style="background-color: #004d26; border: none;">
                            <i class="bi bi-arrow-left-right me-1"></i> Solicitar Traspaso
                        </a>
                    }
                    @if (User.HasClaim("Permiso", "Bienes.Desincorporar"))
                    {
                        <a href="/Movements/SolicitarDesincorporacion?bienId=@Model.ID" class="btn btn-dark btn-sm px-4" style="background-color: #004d26; border: none;">
                            <i class="bi bi-trash me-1"></i> Solicitar Desincorporación
                        </a>
                    }
                    @if (User.HasClaim("Permiso", "Historial.VerPropios") || User.HasClaim("Permiso", "Historial.VerTodos"))
                    {
                        <a href="/Movements/Historial?bienId=@Model.ID" class="btn btn-dark btn-sm px-4" style="background-color: #004d26; border: none;">
                            <i class="bi bi-clock-history me-1"></i> Historial del bien
                        </a>
                    }
                    <a asp-action="Index"  asp-controller="Etiquetas" class="btn btn-light btn-sm px-4 border text-secondary">
                        <i class="bi bi-arrow-left me-1"></i> Volver al listado
                    </a>
                </div>
            </div>
        </div>
    </div>

    <style>
        .form-control:focus, .form-select:focus {
            border-color: #004d26;
            box-shadow: 0 0 0 0.2rem rgba(0, 77, 38, 0.1);
        }

        .form-label {
            font-size: 0.75rem;
            letter-spacing: 0.5px;
        }
    </style>
</body>
</html>