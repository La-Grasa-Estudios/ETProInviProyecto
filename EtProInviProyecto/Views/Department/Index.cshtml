@using EtPro.Models
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@model IEnumerable<Department>

@{
    ViewData["Title"] = "Gestión de Departamentos";
    Layout = "_AdminLayout";
}

<div class="container mt-4">
    <!-- Encabezado con identidad visual -->
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div class="d-flex align-items-center">
            <div style="width: 4px; height: 24px; background-color: #e31e24; margin-right: 10px;"></div>
            <h4 class="mb-0 text-dark fw-bold">@ViewData["Title"]</h4>
        </div>
        <a asp-action="Create" class="btn btn-sm text-white shadow-sm" style="background-color: #004d26; border: none;">
            <i class="bi bi-plus-circle me-1"></i> Nuevo Departamento
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success border-0 shadow-sm py-2 small mb-4">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
        </div>
    }

    <div class="card shadow-sm border-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="border-0 px-4 py-3 text-muted small text-uppercase fw-bold">@Html.DisplayNameFor(model => model.Name)</th>
                        <th class="border-0 py-3 text-muted small text-uppercase fw-bold">Gerente (Manager)</th>
                        <th class="border-0 py-3 text-muted small text-uppercase fw-bold">Custodio</th>
                        <th class="border-0 py-3 text-center text-muted small text-uppercase fw-bold">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="px-4 fw-bold text-dark">@item.Name</td>
                            <td>
                                @if (item.Manager != null)
                                {
                                    <span class="badge bg-light text-dark border"><i class="bi bi-person-fill me-1"></i> @item.Manager.UserName</span>
                                }
                                else
                                {
                                    <span class="text-muted small"><em>No asignado</em></span>
                                }
                            </td>
                            <td>
                                @if (item.Custodian != null)
                                {
                                    <span class="badge bg-light text-dark border"><i class="bi bi-shield-lock me-1"></i> @item.Custodian.UserName</span>
                                }
                                else
                                {
                                    <span class="text-muted small"><em>No asignado</em></span>
                                }
                            </td>
                            <td class="text-center">
                                <div class="btn-group">
                                    <a asp-action="Edit" asp-route-id="@item.ID" class="btn btn-sm btn-outline-secondary" title="Editar">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>
                                    <button type="button" class="btn btn-sm btn-outline-danger" title="Eliminar"
                                            onclick="confirmDelete('@item.ID', '@item.Name')">
                                        <i class="bi bi-trash3"></i>
                                    </button>
                                </div>
                                <form id="delete-form-@item.ID" asp-action="Delete" asp-route-id="@item.ID" method="post" style="display:none;">
                                    @Html.AntiForgeryToken()
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <script>
        function confirmDelete(id, name) {
        Swal.fire({
        title: '¿Eliminar Departamento?',
        text: `¿Está seguro de que desea eliminar el departamento "${name}"? Esta acción no se puede deshacer.`,
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#e31e24',
        cancelButtonColor: '#6c757d',
        confirmButtonText: 'Sí, eliminar',
        cancelButtonText: 'Cancelar',
        reverseButtons: true
        }).then((result) => {
        if (result.isConfirmed) {
        Swal.fire({
        title: 'Eliminando...',
        allowOutsideClick: false,
        didOpen: () => {
        Swal.showLoading();
        }
        });
        document.getElementById(`delete-form-${id}`).submit();
        }
        });
        }
    </script>
}

<style>
    body {
    background-color: #f4f6f9;
    }

    .table thead th {
    font-size: 0.7rem;
    letter-spacing: 0.5px;
    }

    .btn-group .btn {
    padding: 0.25rem 0.5rem;
    }

    .card {
    border-radius: 8px;
    overflow: hidden;
    }
</style>