@using EtPro.Models
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@model Department

@{
    ViewData["Title"] = "Editar Departamento";
    Layout = "_AdminLayout";
}

<div class="container mt-4">
    <div class="card shadow-sm border-0" style="max-width: 750px; margin: auto;">
        <!-- Encabezado con Identidad Visual -->
        <div class="card-header bg-white border-bottom-0 pt-4">
            <div class="d-flex align-items-center">
                <div style="width: 4px; height: 24px; background-color: #e31e24; margin-right: 10px;"></div>
                <h4 class="mb-0 text-dark fw-bold">@ViewData["Title"]</h4>
            </div>
            <p class="text-muted small mb-0 ms-3">Actualice la información y responsables del departamento <strong>@Model.Name</strong>.</p>
            <hr class="mt-3 mb-0" style="opacity: 0.1;">
        </div>

        <div class="card-body p-4">
            <form asp-action="Edit" method="post" id="editDeptForm">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="ID" />

                <div asp-validation-summary="ModelOnly" class="alert alert-danger p-2 small border-0 mb-4"></div>

                <div class="row g-3">
                    <!-- Nombre del Departamento -->
                    <div class="col-12">
                        <label asp-for="Name" class="form-label fw-bold small text-uppercase text-muted">Nombre del Departamento</label>
                        <div class="input-group input-group-sm">
                            <span class="input-group-text bg-light border-end-0"><i class="bi bi-building"></i></span>
                            <input asp-for="Name" class="form-control border-start-0" required />
                        </div>
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <!-- Responsable (Manager) - BUG CORREGIDO: Usando ViewBag.Managers -->
                    <div class="col-md-6">
                        <label asp-for="ManagerID" class="form-label fw-bold small text-uppercase text-muted">Responsable (Manager)</label>
                        <div class="input-group input-group-sm">
                            <span class="input-group-text bg-light border-end-0"><i class="bi bi-person-badge"></i></span>
                            <select asp-for="ManagerID" class="form-select border-start-0"
                                    asp-items="@(ViewBag.Managers as SelectList)">
                                <option value="">-- No asignado --</option>
                            </select>
                        </div>
                    </div>

                    <!-- Custodio - BUG CORREGIDO: Usando ViewBag.Custodians -->
                    <div class="col-md-6">
                        <label asp-for="CustodianID" class="form-label fw-bold small text-uppercase text-muted">Custodio</label>
                        <div class="input-group input-group-sm">
                            <span class="input-group-text bg-light border-end-0"><i class="bi bi-shield-lock"></i></span>
                            <select asp-for="CustodianID" class="form-select border-start-0"
                                    asp-items="@(ViewBag.Custodians as SelectList)">
                                <option value="">-- No asignado --</option>
                            </select>
                        </div>
                    </div>
                </div>

                <!-- Acciones -->
                <div class="d-flex justify-content-between align-items-center mt-5 pt-3 border-top">
                    <a asp-action="Index" class="btn btn-sm btn-light border px-4 text-secondary">
                        <i class="bi bi-arrow-left me-1"></i> Cancelar
                    </a>
                    <button type="submit" class="btn btn-sm px-5 text-white shadow-sm" style="background-color: #004d26; border: none;">
                        <i class="bi bi-check-circle me-1"></i> Guardar Cambios
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <script>
        document.addEventListener('DOMContentLoaded', function () {
        const form = document.getElementById('editDeptForm');

        form.addEventListener('submit', function (e) {
        if (!form.checkValidity()) return;
        e.preventDefault();

        Swal.fire({
        title: '¿Confirmar cambios?',
        text: "Se actualizará la información del departamento en el sistema.",
        icon: 'question',
        showCancelButton: true,
        confirmButtonColor: '#004d26',
        cancelButtonColor: '#6c757d',
        confirmButtonText: 'Sí, guardar',
        cancelButtonText: 'Cancelar',
        reverseButtons: true
        }).then((result) => {
        if (result.isConfirmed) {
        Swal.fire({
        title: 'Actualizando...',
        allowOutsideClick: false,
        didOpen: () => { Swal.showLoading(); }
        });
        form.submit();
        }
        });
        });
        });
    </script>

    <style>
        body {
        background-color: #f4f6f9;
        }

        .form-label {
        font-size: 0.75rem;
        margin-bottom: 0.4rem;
        }

        .form-control:focus, .form-select:focus {
        border-color: #004d26;
        box-shadow: 0 0 0 0.2rem rgba(0, 77, 38, 0.15);
        }

        .input-group-text {
        color: #6c757d;
        }
    </style>
}