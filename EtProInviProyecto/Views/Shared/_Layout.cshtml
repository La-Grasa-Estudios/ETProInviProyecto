@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Gestión de Bienes</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">Gestión de Bienes</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Home" asp-action="Index">Inicio</a>
                        </li>
                        @if (User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Bienes" asp-action="Index">Gestionar Bienes</a>
                            </li>
                            @if (User.HasClaim("Permiso", "Admin.Departamentos"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="Department" asp-action="Index">Departamentos</a>
                                </li>
                            }
                            @if (User.HasClaim("Permiso", "Movimientos.SolicitarTraspaso"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="Movements" asp-action="SolicitarTraspaso">Solicitar Traspaso</a>
                                </li>
                            }
                            @if (User.HasClaim("Permiso", "Bienes.Desincorporar"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="Movements" asp-action="SolicitarDesincorporacion">Solicitar Desincorporación</a>
                                </li>
                            }
                            @if (User.HasClaim("Permiso", "Movimientos.AprobarTraspaso") || User.HasClaim("Permiso", "Movimientos.AprobarDesincorporacion") || User.HasClaim("Permiso", "Movimientos.AprobarIncorporacion"))
                            {
                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle text-dark" href="#" role="button" data-bs-toggle="dropdown">Aprobar</a>
                                    <ul class="dropdown-menu">
                                        @if (User.HasClaim("Permiso", "Movimientos.AprobarTraspaso"))
                                        {
                                            <li><a class="dropdown-item" asp-controller="Movements" asp-action="PendientesTraspaso">Traspasos pendientes</a></li>
                                        }
                                        @if (User.HasClaim("Permiso", "Movimientos.AprobarDesincorporacion"))
                                        {
                                            <li><a class="dropdown-item" asp-controller="Movements" asp-action="PendientesDesincorporacion">Desincorporaciones pendientes</a></li>
                                        }
                                        @if (User.HasClaim("Permiso", "Movimientos.AprobarIncorporacion"))
                                        {
                                            <li><a class="dropdown-item" asp-controller="Movements" asp-action="PendientesIncorporacion">Incorporaciones pendientes</a></li>
                                        }
                                    </ul>
                                </li>
                            }
                            @if (User.HasClaim("Permiso", "Historial.VerPropios") || User.HasClaim("Permiso", "Historial.VerTodos"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="Movements" asp-action="HistorialTraspasos">Historial de Traspasos</a>
                                </li>
                            }
                            @if (User.HasClaim("Permiso", "Admin.Usuarios"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="Admin" asp-action="Index">Admin</a>
                                </li>
                            }
                        }
                    </ul>
                    <ul class="navbar-nav ms-auto">
                        @if (User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item">
                                <span class="navbar-text text-dark me-3">Hola, @User.Identity.Name</span>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Account" asp-action="ChangePassword">Cambiar contraseña</a>
                            </li>
                            <li class="nav-item">
                                <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-link nav-link text-dark">Cerrar sesión</button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Account" asp-action="Login">Iniciar sesión</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>
    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; @DateTime.Now.Year - Gestión de Bienes
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>